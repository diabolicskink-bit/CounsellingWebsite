{
  "name": "vive-counselling",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build && node scripts/prerender-route-metadata.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "preview:qa": "vite preview --host 127.0.0.1 --port 4287 --strictPort",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "qa:site": "npm run build && start-server-and-test preview:qa http://127.0.0.1:4287 test:e2e",
    "audit:lighthouse": "npm run build && start-server-and-test preview:qa http://127.0.0.1:4287 audit:lighthouse:run",
    "audit:lighthouse:run": "node scripts/run-lighthouse.mjs http://127.0.0.1:4287"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "lighthouse": "^13.1.0",
    "playwright": "^1.59.1",
    "start-server-and-test": "^3.0.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.8"
  }
}
