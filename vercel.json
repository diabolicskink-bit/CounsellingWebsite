{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/about",
      "destination": "/working-with-joel",
      "permanent": true
    },
    {
      "source": "/fees",
      "destination": "/contact",
      "permanent": true
    }
  ]
}
